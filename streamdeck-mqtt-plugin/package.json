{
    "scripts": {
        "build": "rollup -c",
        "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.twooding.streamdeck-mqtt-plugin\"",
        "dist": "rollup -c && streamdeck bundle -f com.twooding.streamdeck-mqtt-plugin.sdPlugin",
        "clean": "rm -r *.sdPlugin || rm *.streamDeckPlugin"
    },
    "type": "module",
    "devDependencies": {
        "@elgato/cli": "^1.7.3",
        "@rollup/plugin-commonjs": "^28.0.9",
        "@rollup/plugin-node-resolve": "^15.3.1",
        "@rollup/plugin-typescript": "^12.3.0",
        "@rollup/plugin-json": "^6.1.0",
        "@tsconfig/node20": "^20.1.9",
        "@types/node": "^22.19.17",
        "rollup": "^4.60.1",
        "rollup-plugin-copy": "^3.5.0",
        "rollup-plugin-esbuild": "^6.2.1",
        "rollup-plugin-node-externals": "^7.1.3",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@elgato/streamdeck": "^2.0.4",
        "mqtt": "^5.15.1"
    }
}